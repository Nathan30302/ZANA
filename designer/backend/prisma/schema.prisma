// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String?   @unique
  phone       String?   @unique
  password    String
  firstName   String
  lastName    String
  avatarUrl   String?
  role        Role      @default(CUSTOMER)
  isVerified  Boolean   @default(false)
  isActive    Boolean   @default(true)
  fcmToken    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  venue           Venue?
  mobileProvider  MobileProvider?
  staff           Staff?
  bookings        Booking[]
  reviews         Review[]
  refreshTokens   RefreshToken[]
}

enum Role {
  CUSTOMER
  PROVIDER_MOBILE
  PROVIDER_VENUE
  STAFF
  ADMIN
}

model Venue {
  id            String    @id @default(cuid())
  ownerId       String    @unique
  owner         User      @relation(fields: [ownerId], references: [id])
  name          String
  slug          String    @unique
  description   String?
  category      VenueCategory
  phone         String
  email         String?
  address       String
  city          String    @default("Lusaka")
  latitude      Float
  longitude     Float
  coverPhoto    String?
  photos        String[]
  status        VenueStatus @default(PENDING)
  rating        Float     @default(0)
  reviewCount   Int       @default(0)
  isVerified    Boolean   @default(false)
  amenities     String[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  services      Service[]
  staff         Staff[]
  bookings      Booking[]
  openingHours  OpeningHours[]
  reviews       Review[]
}

enum VenueCategory {
  SALON
  BARBERSHOP
  NAIL_STUDIO
  MAKEUP_STUDIO
}

enum VenueStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

model MobileProvider {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id])
  bio            String?
  portfolioPhotos String[]
  baseLat        Float
  baseLng        Float
  serviceRadius  Int
  status         VenueStatus @default(PENDING)
  rating         Float     @default(0)
  reviewCount    Int       @default(0)
  isVerified     Boolean   @default(false)
  createdAt      DateTime  @default(now())

  services       Service[]
  bookings       Booking[]
  availability   Availability[]
  reviews        Review[]
}

model Service {
  id               String    @id @default(cuid())
  name             String
  description      String?
  category         ServiceCategory
  price            Float
  duration         Int
  isActive         Boolean   @default(true)
  venueId          String?
  venue            Venue?    @relation(fields: [venueId], references: [id])
  mobileProviderId String?
  mobileProvider   MobileProvider? @relation(fields: [mobileProviderId], references: [id])
  bookings         Booking[]
}

enum ServiceCategory {
  HAIRCUT
  HAIR_STYLING
  BRAIDING
  LOCS
  WEAVE
  BEARD_TRIM
  SHAVE
  NAILS
  MAKEUP
  EYEBROWS
}

model Staff {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id])
  venueId     String
  venue       Venue     @relation(fields: [venueId], references: [id])
  title       String?
  avatarUrl   String?
  isActive    Boolean   @default(true)

  availability  Availability[]
  bookings      Booking[]
}

model Availability {
  id               String    @id @default(cuid())
  staffId          String?
  staff            Staff?    @relation(fields: [staffId], references: [id])
  mobileProviderId String?
  mobileProvider   MobileProvider? @relation(fields: [mobileProviderId], references: [id])
  date             DateTime
  startTime        String
  endTime          String
  isBlocked        Boolean @default(false)
}

model OpeningHours {
  id        String    @id @default(cuid())
  venueId   String
  venue     Venue     @relation(fields: [venueId], references: [id])
  dayOfWeek Int
  openTime  String
  closeTime String
  isClosed  Boolean   @default(false)
}

model Booking {
  id               String    @id @default(cuid())
  reference        String    @unique
  customerId       String
  customer         User      @relation(fields: [customerId], references: [id])
  serviceId        String
  service          Service   @relation(fields: [serviceId], references: [id])
  venueId          String?
  venue            Venue?    @relation(fields: [venueId], references: [id])
  mobileProviderId String?
  mobileProvider   MobileProvider? @relation(fields: [mobileProviderId], references: [id])
  staffId          String?
  staff            Staff?    @relation(fields: [staffId], references: [id])
  date             DateTime
  startTime        String
  endTime          String
  status           BookingStatus @default(PENDING)
  serviceMode      ServiceMode
  notes            String?
  clientAddress    String?
  totalAmount      Float
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  review           Review?
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ServiceMode {
  SALON_VISIT
  BARBERSHOP_VISIT
  MOBILE
}

model Review {
  id               String    @id @default(cuid())
  bookingId        String    @unique
  booking          Booking   @relation(fields: [bookingId], references: [id])
  customerId       String
  customer         User      @relation(fields: [customerId], references: [id])
  venueId          String?
  venue            Venue?    @relation(fields: [venueId], references: [id])
  mobileProviderId String?
  mobileProvider   MobileProvider? @relation(fields: [mobileProviderId], references: [id])
  rating           Int
  comment          String?
  createdAt        DateTime  @default(now())
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}